<%- include('../partials/header') %>

    <div class="page-header">
        <h1 class="page-title"><i class="fas fa-file-alt"></i> Request Detail</h1>
        <a href="/borrow" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back</a>
    </div>

    <div class="detail-grid">
        <!-- Left: Request Info -->
        <div>
            <div class="card mb-4">
                <div class="card-header">
                    <h2 class="card-title"><i class="fas fa-user"></i> Borrower Information</h2>
                    <span class="badge badge-<%= borrow.status.toLowerCase() %>">
                        <%= borrow.status %>
                    </span>
                </div>
                <div class="card-body">
                    <div class="info-grid">
                        <div class="info-item">
                            <div class="info-label">Borrower</div>
                            <div class="info-value"><strong>
                                    <%= borrow.borrower %>
                                </strong></div>
                        </div>
                        <div class="info-item">
                            <div class="info-label">Type</div>
                            <div class="info-value">
                                <%= borrow.borrowerType %>
                            </div>
                        </div>
                        <div class="info-item">
                            <div class="info-label">Purpose</div>
                            <div class="info-value">
                                <%= borrow.purpose %>
                            </div>
                        </div>
                        <div class="info-item">
                            <div class="info-label">Date Needed</div>
                            <div class="info-value">
                                <%= moment(borrow.dateNeeded).format('MMMM D, YYYY') %>
                            </div>
                        </div>
                        <div class="info-item">
                            <div class="info-label">Return By</div>
                            <div class="info-value">
                                <%= moment(borrow.dateToReturn).format('MMMM D, YYYY') %>
                            </div>
                        </div>
                        <div class="info-item">
                            <div class="info-label">Requested By</div>
                            <div class="info-value">
                                <%= borrow.requestedBy ? borrow.requestedBy.name : '-' %>
                            </div>
                        </div>
                        <% if (borrow.notes) { %>
                            <div class="info-item info-full">
                                <div class="info-label">Notes</div>
                                <div class="info-value">
                                    <%= borrow.notes %>
                                </div>
                            </div>
                            <% } %>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <h2 class="card-title"><i class="fas fa-boxes"></i> Items</h2>
                </div>
                <div class="card-body p-0">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Equipment</th>
                                <th>Quantity</th>
                                <th>Returned</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% borrow.items.forEach((item, i)=> { %>
                                <tr>
                                    <td>
                                        <%= i+1 %>
                                    </td>
                                    <td>
                                        <%= item.equipmentName %>
                                    </td>
                                    <td>
                                        <%= item.quantity %>
                                    </td>
                                    <td>
                                        <% if (item.returned) { %><span class="text-success"><i
                                                    class="fas fa-check"></i> Yes</span>
                                            <% } else { %><span class="text-muted">No</span>
                                                <% } %>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="card mb-4">
                <div class="card-header">
                    <h2 class="card-title"><i class="fas fa-cogs"></i> Actions</h2>
                </div>
                <div class="card-body">
                    <% if (borrow.status==='Pending' ) { %>
                        <form action="/borrow/<%= borrow._id %>/approve" method="POST" class="inline-form">
                            <button class="btn btn-success" onclick="return confirm('Approve this request?')"><i
                                    class="fas fa-check"></i> Approve</button>
                        </form>
                        <button class="btn btn-danger"
                            onclick="document.getElementById('rejectModal').style.display='flex'"><i
                                class="fas fa-times"></i> Reject</button>
                        <% } else if (borrow.status==='Approved' ) { %>
                            <form action="/borrow/<%= borrow._id %>/release" method="POST" class="inline-form">
                                <button class="btn btn-primary" onclick="return confirm('Mark items as released?')"><i
                                        class="fas fa-shipping-fast"></i> Mark as Released</button>
                            </form>
                            <% } else if (borrow.status==='Released' ) { %>
                                <form action="/borrow/<%= borrow._id %>/return" method="POST" class="inline-form">
                                    <button class="btn btn-success"
                                        onclick="return confirm('Confirm all items have been returned?')"><i
                                            class="fas fa-undo"></i> Confirm Return</button>
                                </form>
                                <% } else { %>
                                    <p class="text-muted"><i class="fas fa-info-circle"></i> No actions available for
                                        <strong>
                                            <%= borrow.status %>
                                        </strong> requests.</p>
                                    <% } %>
                </div>
            </div>
        </div>

        <!-- Right: Audit Trail -->
        <div class="card">
            <div class="card-header">
                <h2 class="card-title"><i class="fas fa-stream"></i> Audit Trail</h2>
            </div>
            <div class="card-body">
                <% if (borrow.approvedBy) { %>
                    <div class="trail-item">
                        <div class="trail-icon trail-approved"><i class="fas fa-check"></i></div>
                        <div>
                            <div class="trail-action">Approved by <strong>
                                    <%= borrow.approvedBy.name %>
                                </strong></div>
                            <div class="trail-time">
                                <%= moment(borrow.approvedAt).format('MMM D, YYYY h:mm A') %>
                            </div>
                        </div>
                    </div>
                    <% } %>
                        <% if (borrow.rejectedBy) { %>
                            <div class="trail-item">
                                <div class="trail-icon trail-rejected"><i class="fas fa-times"></i></div>
                                <div>
                                    <div class="trail-action">Rejected by <strong>
                                            <%= borrow.rejectedBy.name %>
                                        </strong></div>
                                    <% if(borrow.rejectionReason) { %>
                                        <div class="trail-note">Reason: <%= borrow.rejectionReason %>
                                        </div>
                                        <% } %>
                                            <div class="trail-time">
                                                <%= moment(borrow.rejectedAt).format('MMM D, YYYY h:mm A') %>
                                            </div>
                                </div>
                            </div>
                            <% } %>
                                <% if (borrow.releasedBy) { %>
                                    <div class="trail-item">
                                        <div class="trail-icon trail-released"><i class="fas fa-shipping-fast"></i>
                                        </div>
                                        <div>
                                            <div class="trail-action">Released by <strong>
                                                    <%= borrow.releasedBy.name %>
                                                </strong></div>
                                            <div class="trail-time">
                                                <%= moment(borrow.releasedAt).format('MMM D, YYYY h:mm A') %>
                                            </div>
                                        </div>
                                    </div>
                                    <% } %>
                                        <% if (borrow.returnReceivedBy) { %>
                                            <div class="trail-item">
                                                <div class="trail-icon trail-returned"><i class="fas fa-undo"></i></div>
                                                <div>
                                                    <div class="trail-action">Return received by <strong>
                                                            <%= borrow.returnReceivedBy.name %>
                                                        </strong></div>
                                                    <div class="trail-time">
                                                        <%= moment(borrow.returnedAt).format('MMM D, YYYY h:mm A') %>
                                                    </div>
                                                </div>
                                            </div>
                                            <% } %>
                                                <% if (!borrow.approvedBy && !borrow.rejectedBy && !borrow.releasedBy &&
                                                    !borrow.returnReceivedBy) { %>
                                                    <p class="text-muted text-center py-4">Awaiting action.</p>
                                                    <% } %>
            </div>
        </div>
    </div>

    <!-- Reject Modal -->
    <div class="modal-overlay" id="rejectModal" style="display:none"
        onclick="if(event.target===this)this.style.display='none'">
        <div class="modal-box">
            <div class="modal-header">
                <h3><i class="fas fa-times-circle"></i> Reject Request</h3>
            </div>
            <form action="/borrow/<%= borrow._id %>/reject" method="POST">
                <div class="modal-body">
                    <div class="form-group">
                        <label class="form-label">Reason for Rejection</label>
                        <textarea name="reason" class="form-control" rows="3" placeholder="Enter reason..."
                            required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline"
                        onclick="document.getElementById('rejectModal').style.display='none'">Cancel</button>
                    <button type="submit" class="btn btn-danger">Confirm Reject</button>
                </div>
            </form>
        </div>
    </div>

    <%- include('../partials/footer') %>